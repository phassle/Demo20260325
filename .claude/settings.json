{
  "permissions": {
    "allow": [
      "Bash(dotnet *)",
      "Bash(npm *)",
      "Bash(git *)",
      "Bash(cd *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(dotnet ef database update *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/perhassle/source/Monterro/InfuseAI-Demos/Demo20260325/backend && dotnet format --verify-no-changes",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/perhassle/source/Monterro/InfuseAI-Demos/Demo20260325/backend && dotnet test && dotnet build && cd /Users/perhassle/source/Monterro/InfuseAI-Demos/Demo20260325/frontend && npx vitest run 2>/dev/null || true",
            "timeout": 180
          }
        ]
      }
    ]
  }
}
